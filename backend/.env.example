# ============================================================
# 온비드 공매 추천 서비스 환경변수 설정
# 복사 후 .env 파일로 저장: copy .env.example .env  (Windows)
# ============================================================

# ─────────────────────────────────────────────
# 온비드 OpenAPI (공공데이터포털)
# 발급: https://www.data.go.kr/data/15005586/openapi.do
# ─────────────────────────────────────────────
ONBID_API_KEY=

# ─────────────────────────────────────────────
# 국토교통부 실거래가 API (공공데이터포털)
# 발급: https://www.data.go.kr/data/15057511/openapi.do
# ─────────────────────────────────────────────
MOLIT_API_KEY=

# ─────────────────────────────────────────────
# Google Gemini API (파산 공고문 AI 분석)
# 발급: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# 네이버 클라우드 플랫폼 Maps API (지도 연동)
# ─────────────────────────────────────────────
NAVER_CLIENT_ID=

# ─────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────
APP_NAME=온비드 공매 추천 서비스
DEBUG=false
DB_URL=sqlite:///./onbid.db

# ─────────────────────────────────────────────
# 스케줄러 (매일 자동 동기화 시각)
# ─────────────────────────────────────────────
SYNC_HOUR=9
SYNC_MINUTE=0

# ─────────────────────────────────────────────
# 분석 파라미터
# ─────────────────────────────────────────────
MIN_GAP_PCT=10.0
TOP_N=20
MAX_PAGES=10

# ─────────────────────────────────────────────
# CORS (프론트엔드 URL)
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─────────────────────────────────────────────
# 카카오 JavaScript API (지도 연동)
# 발급: https://developers.kakao.com/
# ─────────────────────────────────────────────
KAKAO_JS_API_KEY=
